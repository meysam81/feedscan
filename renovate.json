{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>meysam81/.github"],
  "packageRules": [
    {
      "description": "Group minor Go (backend) updates into non-major dependencies",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor"],
      "groupName": "non-major dependencies",
      "groupSlug": "non-major-deps"
    },
    {
      "description": "Group minor + patch landing-page updates into one PR",
      "matchFileNames": ["landing-page/package.json"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "landing-page non-major dependencies",
      "groupSlug": "landing-page-non-major-deps"
    },
    {
      "description": "Group minor + patch SPA updates into one PR",
      "matchFileNames": ["package.json"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "spa non-major dependencies",
      "groupSlug": "spa-non-major-deps"
    }
  ]
}
